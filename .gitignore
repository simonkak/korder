.venv/
__pycache__/
*.egg-info/
dist/
build/
*.pyc
.DS_Store
.python-version
uv.lock
tests.md
bench-results/*
!bench-results/*.json
# Dev launcher (per-user — uses absolute Path= and `uv run korder`).
# The bundled .desktop in src/korder/ui/icons/ is the one shipped to
# end users; this one stays personal.
/korder.desktop

# Piper voice models. `python -m piper.download_voices` defaults to
# CWD when --data-dir isn't passed; the canonical location is
# ~/.local/share/piper. Don't commit accidentally-downloaded copies.
/*.onnx
/*.onnx.json
